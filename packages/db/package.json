{
  "name": "@repo/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "supabase": "pnpm with-env supabase",
    "drizzle-kit": "pnpm with-env drizzle-kit",
    "seed": "pnpm with-env tsx src/seed/initial.ts",
    "start": "pnpm with-env supabase status || supabase start",
    "stop": "pnpm with-env supabase stop",
    "reset": "pnpm with-env supabase db reset && pnpm push",
    "status": "pnpm with-env supabase status",
    "supabase-test": "pnpm with-env supabase db test",
    "push": "pnpm with-env drizzle-kit push",
    "push-remote": "dotenv -e ../../.env.production.local -- drizzle-kit push",
    "studio": "pnpm with-env drizzle-kit studio",
    "with-env": "dotenv -e ../../.env --",
    "generate-auth-schema": "pnpm with-env pnpx @better-auth/cli generate --config ../api/src/auth/auth.ts --output ./src/drizzle-schema-auth.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kyh/tsconfig": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.10",
    "supabase": "^2.92.1",
    "typescript": "catalog:"
  }
}
