{
  "name": "@repo/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./drizzle-client": "./src/drizzle-client.ts",
    "./drizzle-schema": "./src/drizzle-schema.ts",
    "./drizzle-schema-auth": "./src/drizzle-schema-auth.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit",
    "supabase": "pnpm with-env supabase",
    "drizzle:kit": "pnpm with-env drizzle-kit",
    "start": "pnpm with-env supabase status || (supabase start && supabase seed buckets)",
    "stop": "pnpm with-env supabase stop",
    "reset": "pnpm with-env supabase db reset && pnpm push && pnpm with-env supabase seed buckets",
    "status": "pnpm with-env supabase status",
    "push": "pnpm with-env drizzle-kit push",
    "push:remote": "dotenv -e ../../.env.production.local -- drizzle-kit push",
    "studio": "pnpm with-env drizzle-kit studio",
    "with-env": "dotenv -e ../../.env --",
    "generate:auth-schema": "pnpm with-env pnpx @better-auth/cli generate --config ../api/src/auth/auth.ts --output ./src/drizzle-schema-auth.ts"
  },
  "dependencies": {
    "@t3-oss/env-core": "catalog:",
    "drizzle-orm": "catalog:",
    "postgres": "^3.4.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kyh/tsconfig": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.10",
    "supabase": "^2.109.1",
    "typescript": "catalog:"
  }
}
