{
  "name": "@repo/mdx",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.tsx",
    "./content": {
      "types": "./.content-collections/generated/index.d.ts",
      "default": "./.content-collections/generated/index.js"
    }
  },
  "scripts": {
    "build": "content-collections build",
    "clean": "git clean -xdf .cache .turbo dist node_modules .content-collections",
