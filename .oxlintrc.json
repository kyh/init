{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc/json-schema-for-oxfmt/npm/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "dist",
    "node_modules",
    "pnpm-lock.yaml",
    "*.tsbuildinfo",
    ".next",
    ".expo",
    ".wxt",
    ".output",
    "out"
  ],
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "react",
    "nextjs",
    "jsx-a11y",
    "oxc",
    "node",
    "promise"
  ],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "eslint/no-shadow": "off",
    "eslint/no-await-in-loop": "off",
    "eslint/no-underscore-dangle": [
      "warn",
      { "allow": ["__dirname", "__registerFileInput", "__PACKAGED_WEBAPP_URL__"] }
    ],
    "react/no-unstable-nested-components": ["warn", { "allowAsProps": true }],
    "jsx-a11y/prefer-tag-over-role": "off"
  }
}
