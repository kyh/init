{
  "name": "@repo/nextjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "fumadocs-mdx",
    "build": "pnpm with-env next build --turbopack",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "pnpm with-env next dev --turbopack",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "pnpm with-env next start",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "prettier": "@kyh/prettier-config",
  "dependencies": {
    "@ai-sdk/react": "^2.0.39",
    "@repo/api": "workspace:^",
    "@repo/db": "workspace:^",
    "@repo/ui": "workspace:^",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-query-devtools": "^5.87.3",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "ai": "^5.0.39",
    "better-auth": "^1.3.9",
    "fumadocs-core": "^15.7.10",
    "fumadocs-mdx": "^11.9.0",
    "fumadocs-ui": "^15.7.10",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kyh/eslint-config": "catalog:",
    "@kyh/prettier-config": "catalog:",
    "@kyh/tsconfig": "catalog:",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/mdx": "^2.0.13",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "postcss": "^8.5.6",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
