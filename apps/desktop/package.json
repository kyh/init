{
  "name": "@repo/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Init desktop app",
  "author": "kyh",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "build:linux": "pnpm build && electron-builder --linux",
    "build:mac": "node --import tsx ./scripts/build-mac.ts",
    "build:win": "pnpm build && electron-builder --win",
    "clean": "rm -rf .cache out dist",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "catalog:",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
