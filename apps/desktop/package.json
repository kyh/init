{
  "name": "@repo/desktop",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsdown",
    "build:linux": "pnpm build && electron-builder --linux",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:win": "pnpm build && electron-builder --win",
    "clean": "git clean -xdf .cache dist release node_modules",
    "dev": "tsdown && concurrently -k \"tsdown --watch\" \"electron .\"",
    "start": "electron .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "concurrently": "^9.1.2",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "tsdown": "^0.12.4",
    "typescript": "catalog:"
  }
}
