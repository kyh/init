{
  "name": "@repo/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env wxt",
    "dev:firefox": "pnpm with-env wxt -b firefox",
    "build": "pnpm with-env wxt build",
    "build:firefox": "pnpm with-env wxt build -b firefox",
    "zip": "pnpm with-env wxt zip",
    "zip:firefox": "pnpm with-env wxt zip -b firefox",
    "clean": "git clean -xdf .cache .turbo .output .wxt node_modules",
    "typecheck": "wxt prepare && tsc --noEmit",
    "postinstall": "wxt prepare",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@repo/ui": "workspace:*",
    "lucide-react": "^0.562.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@kyh/tsconfig": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "wxt": "^0.20.18"
  }
}
