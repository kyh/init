{
  "name": "@repo/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env vite",
    "build": "pnpm with-env vite build",
    "preview": "pnpm with-env vite preview",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "prettier": "@kyh/prettier-config",
  "dependencies": {
    "@repo/ui": "workspace:*",
    "lucide-react": "^0.559.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@kyh/eslint-config": "catalog:",
    "@kyh/prettier-config": "catalog:",
    "@kyh/tsconfig": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/chrome": "^0.1.32",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
